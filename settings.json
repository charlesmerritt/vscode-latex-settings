{
    "latex-workshop.latex.tools": [
      {
        "name": "latexmk",
        "command": "latexmk",
        "args": [
          "-pdf",
          "-interaction=nonstopmode",
          "-file-line-error",
          "-synctex=1",
          "-outdir=build",
          "%DOC%"
        ]
      }
    ],
    "latex-workshop.latex.recipes": [
      {
        "name": "latexmk (build/)",
        "tools": ["latexmk"]
      }
    ],
    "latex-workshop.latex.recipe.default": "latexmk (build/)"
  }
